---
import type { Tool } from "../lib/tools";

interface Props {
  tool: Tool;
}
const { tool } = Astro.props;
const icon = tool.kind === "photo" ? "🖼️" : "🎬";
---

<a href={`/${tool.slug}`} class="k-toolcard k-card">
  <span class="k-toolcard__icon" aria-hidden="true">{icon}</span>
  <span class="k-toolcard__body">
    <span class="k-toolcard__title">
      {tool.label}
      {tool.status === "phase-2" && <span class="k-toolcard__badge">soon</span>}
    </span>
    <span class="k-toolcard__tagline">{tool.tagline}</span>
  </span>
</a>

<style>
  .k-toolcard {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.9rem 1rem;
    transition:
      border-color 0.15s ease,
      transform 0.1s ease;
  }
  .k-toolcard:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }
  .k-toolcard__icon {
    font-size: 1.35rem;
    line-height: 1.2;
  }
  .k-toolcard__body {
    display: grid;
    gap: 0.15rem;
  }
  .k-toolcard__title {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 600;
    color: var(--color-fg);
    font-size: 0.95rem;
  }
  .k-toolcard__badge {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.1rem 0.35rem;
    border-radius: 999px;
    background: var(--color-surface-2);
    color: var(--color-fg-subtle);
  }
  .k-toolcard__tagline {
    color: var(--color-fg-muted);
    font-size: 0.85rem;
    line-height: 1.4;
  }
</style>
