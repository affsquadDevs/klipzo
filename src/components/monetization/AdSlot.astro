---
/**
 * Reusable ad slot (§7). With a manual `slot` id it emits a real
 * <ins class="adsbygoogle"> unit (fixed height reserved to prevent CLS). Without one
 * it renders NOTHING in production — the site runs AdSense Auto Ads, which places ads
 * itself, so a manual reserved slot would just show an empty gap. In dev it renders a
 * neutral placeholder as a layout reference.
 *
 * Placement rules (enforced by callers, not this component):
 *  - Content/landing/guide pages only, below the fold.
 *  - On the editor route: at most ONE slot, never over the canvas/controls, never on
 *    empty/processing/error states. Never inside the isolated /editor exception route.
 */
import { MONETIZATION, isConfigured } from "../../config/site";

interface Props {
  /** AdSense slot id (data-ad-slot). */
  slot?: string;
  /** Reserved height in px (mobile) — desktop can grow via `format`. */
  minHeight?: number;
  format?: "auto" | "fluid" | "rectangle" | "horizontal";
  label?: string;
  class?: string;
}

const {
  slot,
  minHeight = 280,
  format = "auto",
  label = "Advertisement",
  class: className = "",
} = Astro.props;

const publisher = isConfigured(MONETIZATION.adsensePublisherId)
  ? MONETIZATION.adsensePublisherId
  : null;
const live = Boolean(publisher && slot);
// Only show the reserved placeholder in dev. In production without a manual slot id,
// render nothing and let AdSense Auto Ads handle placement.
const showDevPlaceholder = !live && import.meta.env.DEV;
---

{
  (live || showDevPlaceholder) && (
    <aside
      class:list={["k-adslot-wrap", className]}
      style={`min-height:${minHeight}px`}
      aria-label={label}
      data-ad-container
    >
      <span class="k-adslot-label">{label}</span>
      {live ? (
        <ins
          class="adsbygoogle"
          style={`display:block;min-height:${minHeight}px`}
          data-ad-client={publisher}
          data-ad-slot={slot}
          data-ad-format={format}
          data-full-width-responsive="true"
        />
      ) : (
        <div class="k-adslot" style={`min-height:${minHeight}px`}>
          Ad slot ({minHeight}px reserved), inactive until a publisher id is set
        </div>
      )}
    </aside>
  )
}

{live && <script is:inline set:html={`(adsbygoogle = window.adsbygoogle || []).push({});`} />}

<style>
  .k-adslot-wrap {
    display: block;
    width: 100%;
    margin-block: 1.5rem;
  }
  .k-adslot-label {
    display: block;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-fg-subtle);
    margin-bottom: 0.35rem;
    text-align: center;
  }
</style>
