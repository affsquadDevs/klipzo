---
import BaseLayout from "../layouts/BaseLayout.astro";
import ToolCard from "../components/ToolCard.astro";
import FaqAccordion from "../components/FaqAccordion.astro";
import AdSlot from "../components/monetization/AdSlot.astro";
import { t } from "../i18n";
import { SITE } from "../config/site";
import { PHOTO_TOOLS, VIDEO_TOOLS } from "../lib/tools";
import { organizationSchema, websiteSchema, webApplicationSchema, faqSchema } from "../lib/seo";
import type { FaqItem } from "../lib/seo";

const faqs: FaqItem[] = [
  {
    question: "Is Klipzo really free?",
    answer:
      "Yes. Every feature is free with no account, no watermark on your exports, and no paid tier. Klipzo is supported by ads on the surrounding guide pages, not by charging you.",
  },
  {
    question: "Are my photos and videos uploaded anywhere?",
    answer:
      "No. All editing happens inside your browser on your own device. Your files are never sent to a server, to us, or to any third party — that is the core promise of Klipzo.",
  },
  {
    question: "Do I need to create an account?",
    answer:
      "Never. There is no sign-up, no login, and no user database. You open the editor and start working immediately.",
  },
  {
    question: "What happens to my files when I leave?",
    answer:
      "Your work lives only for the current session. Klipzo uses on-device scratch storage so a big file survives an accidental refresh, and you can wipe everything at any time with the ‘Clear session’ button. Nothing persists across devices because nothing ever leaves your device.",
  },
  {
    question: "Which browsers work best?",
    answer:
      "Photo editing works in any modern browser. For heavy video export, desktop Chrome or Edge give the fastest results thanks to hardware-accelerated WebCodecs. Klipzo detects your browser’s capabilities and falls back gracefully, telling you honestly if a specific export isn’t supported.",
  },
];

// Plain node array — <Seo>/<JsonLd> wraps it in a single @graph. Wrapping with
// graph() here produced a doubly-nested @graph on the homepage.
const schema = [
  organizationSchema(),
  websiteSchema(),
  webApplicationSchema({
    features: [
      "Crop, resize, rotate, and adjust photos",
      "Filters, text, and annotations",
      "Trim, split, and merge video",
      "Convert image and video formats",
      "Video to GIF, extract audio",
      "Export with no watermark, EXIF stripped",
    ],
  }),
  faqSchema(faqs),
];
---

<BaseLayout title={`${SITE.brand} — Free In-Browser Photo & Video Editor`} description={SITE.description} theme="light" schema={schema}>
  <!-- Hero -->
  <section class="k-hero">
    <div class="k-hero__decor" aria-hidden="true">
      <span class="k-hero__grid"></span>
      <span class="k-hero__orb k-hero__orb--a"></span>
      <span class="k-hero__orb k-hero__orb--b"></span>
      <span class="k-hero__chip k-hero__chip--1">✂️</span>
      <span class="k-hero__chip k-hero__chip--2">🎬</span>
      <span class="k-hero__chip k-hero__chip--3">🖼️</span>
      <span class="k-hero__chip k-hero__chip--4">🎵</span>
      <span class="k-hero__chip k-hero__chip--5">✨</span>
    </div>
    <div class="k-container">
      <p class="k-hero__eyebrow">🔒 100% on-device · nothing uploaded</p>
      <h1 class="k-hero__title">{t("home.hero.title")}</h1>
      <p class="k-hero__subtitle">{t("home.hero.subtitle")}</p>
      <div class="k-hero__actions">
        <a href="/editor" class="k-btn k-btn-primary k-hero__cta">{t("home.hero.ctaPrimary")}</a>
        <a href="/how-it-works" class="k-btn k-btn-ghost">{t("home.hero.ctaSecondary")}</a>
      </div>
      <ul class="k-hero__trust">
        <li>✓ {t("home.trust.noUpload")}</li>
        <li>✓ {t("home.trust.noAccount")}</li>
        <li>✓ {t("home.trust.onDevice")}</li>
        <li>✓ {t("home.trust.free")}</li>
      </ul>
    </div>
  </section>

  <!-- Photo tools -->
  <section class="k-container k-section">
    <div class="k-section__head">
      <h2>Photo tools</h2>
      <p>Edit, convert, and optimize images — instantly, in your browser.</p>
    </div>
    <div class="k-grid">
      {PHOTO_TOOLS.map((tool) => <ToolCard tool={tool} />)}
    </div>
  </section>

  <!-- Video tools -->
  <section class="k-container k-section">
    <div class="k-section__head">
      <h2>Video tools</h2>
      <p>Trim, convert, and reframe video with hardware-accelerated WebCodecs.</p>
    </div>
    <div class="k-grid">
      {VIDEO_TOOLS.map((tool) => <ToolCard tool={tool} />)}
    </div>
  </section>

  <!-- Why private -->
  <section class="k-container k-section">
    <div class="k-why">
      <div class="k-why__item k-card">
        <h3>🔒 Nothing leaves your device</h3>
        <p>Your media is decoded, edited, and exported entirely in the browser. No upload, no cloud, no exposure.</p>
      </div>
      <div class="k-why__item k-card">
        <h3>⚡ Instant, no round-trip</h3>
        <p>There is no server to wait on. Open a file and start editing immediately — even large videos.</p>
      </div>
      <div class="k-why__item k-card">
        <h3>🙅 No account, no watermark</h3>
        <p>No sign-up, no email, no “pro” upsell. Export clean files at full quality, free.</p>
      </div>
    </div>
    <p class="k-why__cta">
      <a href="/how-it-works" class="k-btn k-btn-ghost">Learn how on-device editing works →</a>
    </p>
  </section>

  <!-- Open source -->
  <section class="k-container k-section">
    <div class="k-oss">
      <p class="k-oss__eyebrow">⭐ Open source</p>
      <h2>Don’t take our word for it — read the code</h2>
      <p>
        Klipzo is fully open source. The entire editor lives in one public repository, so you
        can verify that nothing is uploaded, audit exactly how your files are handled, or run
        your own copy. Privacy you can check beats privacy you’re only promised.
      </p>
      <div class="k-oss__actions">
        <a
          href={SITE.repo}
          class="k-btn k-btn-primary k-oss__gh"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"
            ></path>
          </svg>
          View source on GitHub
        </a>
      </div>
      <p class="k-oss__note">MIT licensed · issues &amp; pull requests welcome</p>
    </div>
  </section>

  <!-- Ad (content layer, below the fold, reserved height) -->
  <section class="k-container">
    <AdSlot minHeight={280} />
  </section>

  <!-- FAQ -->
  <section class="k-container k-section">
    <FaqAccordion items={faqs} />
  </section>
</BaseLayout>

<style>
  .k-hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(3rem, 8vw, 6rem) clamp(2rem, 5vw, 4rem);
    background:
      radial-gradient(ellipse 80% 60% at 50% -10%, color-mix(in srgb, var(--color-accent) 14%, transparent), transparent 70%);
    text-align: center;
  }
  .k-hero > .k-container {
    position: relative;
    z-index: 1;
  }
  .k-hero__decor {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
    /* Dissolve the decor (orbs/grid/chips) toward the bottom so it melts into the
       next section instead of hard-clipping at the hero's edge. */
    -webkit-mask-image: linear-gradient(to bottom, #000 55%, transparent 92%);
    mask-image: linear-gradient(to bottom, #000 55%, transparent 92%);
  }
  /* Faint dot grid, fading out toward the edges. */
  .k-hero__grid {
    position: absolute;
    inset: -1px;
    background-image: radial-gradient(
      color-mix(in srgb, var(--color-fg) 9%, transparent) 1px,
      transparent 1.4px
    );
    background-size: 24px 24px;
    -webkit-mask-image: radial-gradient(ellipse 60% 55% at 50% 32%, #000 28%, transparent 72%);
    mask-image: radial-gradient(ellipse 60% 55% at 50% 32%, #000 28%, transparent 72%);
  }
  /* Soft gradient orbs. */
  .k-hero__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(56px);
  }
  .k-hero__orb--a {
    width: 24rem;
    height: 24rem;
    top: -9rem;
    left: -7rem;
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--color-accent) 55%, transparent),
      transparent 68%
    );
    opacity: 0.5;
  }
  .k-hero__orb--b {
    width: 22rem;
    height: 22rem;
    right: -8rem;
    bottom: -11rem;
    background: radial-gradient(circle, #8a5cff, transparent 68%);
    opacity: 0.32;
  }
  /* Floating tool chips (desktop only; ambient, behind the copy). */
  .k-hero__chip {
    position: absolute;
    display: none;
    place-items: center;
    width: 3rem;
    height: 3rem;
    font-size: 1.35rem;
    border-radius: 0.9rem;
    background: color-mix(in srgb, var(--color-surface) 82%, transparent);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-panel);
    backdrop-filter: blur(4px);
    animation: k-hero-float 7s ease-in-out infinite;
  }
  .k-hero__chip--1 {
    top: 17%;
    left: 8%;
    transform: rotate(-8deg);
    animation-delay: 0s;
  }
  .k-hero__chip--2 {
    top: 29%;
    right: 9%;
    transform: rotate(7deg);
    animation-delay: -1.2s;
  }
  .k-hero__chip--3 {
    bottom: 19%;
    left: 13%;
    transform: rotate(6deg);
    animation-delay: -2.4s;
  }
  .k-hero__chip--4 {
    bottom: 23%;
    right: 12%;
    transform: rotate(-6deg);
    animation-delay: -3.6s;
  }
  .k-hero__chip--5 {
    top: 12%;
    right: 22%;
    transform: rotate(10deg);
    animation-delay: -4.8s;
  }
  @keyframes k-hero-float {
    0%,
    100% {
      translate: 0 0;
    }
    50% {
      translate: 0 -10px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .k-hero__chip {
      animation: none;
    }
  }
  @media (min-width: 820px) {
    .k-hero__chip {
      display: grid;
    }
  }
  .k-hero__eyebrow {
    display: inline-block;
    font-size: 0.82rem;
    color: var(--color-fg-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 0.35rem 0.8rem;
    border-radius: 999px;
    margin-bottom: 1.25rem;
  }
  .k-hero__title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 720;
    line-height: 1.05;
    max-width: 20ch;
    margin-inline: auto;
  }
  .k-hero__subtitle {
    margin: 1.1rem auto 0;
    max-width: 42rem;
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--color-fg-muted);
    line-height: 1.6;
  }
  .k-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 1.75rem;
  }
  .k-hero__cta {
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
  }
  .k-hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    justify-content: center;
    margin-top: 2rem;
    color: var(--color-fg-subtle);
    font-size: 0.88rem;
  }
  .k-section {
    padding-block: clamp(2rem, 5vw, 3.5rem);
  }
  .k-section__head {
    margin-bottom: 1.5rem;
  }
  .k-section__head h2 {
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    font-weight: 680;
  }
  .k-section__head p {
    color: var(--color-fg-muted);
    margin-top: 0.35rem;
  }
  .k-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15.5rem, 1fr));
    gap: 0.85rem;
  }
  .k-why {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  .k-why__item {
    padding: 1.4rem;
  }
  .k-why__item h3 {
    font-size: 1.1rem;
    font-weight: 620;
    margin-bottom: 0.5rem;
  }
  .k-why__item p {
    color: var(--color-fg-muted);
    line-height: 1.6;
  }
  .k-why__cta {
    margin-top: 1.5rem;
    text-align: center;
  }
  @media (min-width: 720px) {
    .k-why {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .k-oss {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg, 1rem);
    background:
      radial-gradient(
        ellipse 70% 130% at 100% 0%,
        color-mix(in srgb, var(--color-accent) 11%, transparent),
        transparent 68%
      ),
      var(--color-surface);
    padding: clamp(1.75rem, 4vw, 2.75rem);
    text-align: center;
  }
  .k-oss__eyebrow {
    color: var(--color-accent);
    font-weight: 600;
    font-size: 0.82rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .k-oss h2 {
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    font-weight: 680;
    margin-top: 0.4rem;
  }
  .k-oss > p {
    color: var(--color-fg-muted);
    max-width: 46rem;
    margin: 0.75rem auto 0;
    line-height: 1.6;
  }
  .k-oss__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 1.6rem;
  }
  .k-oss__gh {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.75rem 1.4rem;
    font-size: 1rem;
  }
  .k-oss__note {
    margin-top: 0.9rem;
    font-size: 0.82rem;
    color: var(--color-fg-subtle);
  }
</style>
