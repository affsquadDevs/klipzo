# Klipzo response headers (Cloudflare Pages / Netlify).
# See README "Cross-origin isolation decision" (§3.6).
#
# DEFAULT (ISOLATION.isolateEditorRoute = false): the whole site runs WITHOUT
# cross-origin isolation, so AdSense/GA4/GTM work on every page. We set only COOP
# (same-origin-allow-popups) which protects against tabnabbing and breaks nothing.

/*
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Referrer-Policy: strict-origin-when-cross-origin
  X-Content-Type-Options: nosniff
  Permissions-Policy: camera=(), microphone=(), geolocation=(), browsing-topics=()

# WebAssembly must be served with the correct MIME for streaming compilation.
/*.wasm
  Content-Type: application/wasm
  Cache-Control: public, max-age=31536000, immutable

# Long-cache hashed build assets.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# On-device model assets (background removal, etc.) are large + immutable.
/models/*
  Cache-Control: public, max-age=31536000, immutable

# ----------------------------------------------------------------------------
# ISOLATED-EDITOR EXCEPTION (only if multi-threaded ffmpeg.wasm is later needed).
# Flip ISOLATION.isolateEditorRoute = true and UNCOMMENT the block below. It scopes
# full isolation to /editor with COEP: credentialless (so third-party resources don't
# all need CORP opt-in). Keep ads OFF this route.
#
# /editor
#   Cross-Origin-Opener-Policy: same-origin
#   Cross-Origin-Embedder-Policy: credentialless
# /editor/*
#   Cross-Origin-Opener-Policy: same-origin
#   Cross-Origin-Embedder-Policy: credentialless
